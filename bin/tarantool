#!/usr/bin/env bash
set -e

IMAGE="tnt-tg-bot"

# Образ ставит нужные роки внутри себя (см. Dockerfile).
# После первой сборки — из кэша (быстро).
docker build -t "$IMAGE" .

docker run -it --rm \
  --network host \
  -p 4401:3301 \
  \
  -e BOT_TOKEN="${BOT_TOKEN:-"WHERE_TOKEN?"}" \
  \
  -v "$(pwd)/bot:/opt/tarantool/bot:ro" \
  -v "$(pwd)/examples:/opt/tarantool/examples:ro" \
  \
  -w /opt/tarantool \
  \
  "$IMAGE" tarantool "$@"
